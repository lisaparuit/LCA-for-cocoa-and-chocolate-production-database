class DataBase(object):
    """ Database containing the informations """

    def __init__(self):
        """ Opens the database"""
        # Open the database
        self.connection = sql.connect("ProjectUB.db")
        self.cursor = self.connection.cursor()
        # Confirmation
        if self.connection and self.cursor:
            tkmb.showinfo("Info",'You are connected to the database')
    
    def close(self) :
        """ Closes the database"""
        # Close the database
        self.cursor.close()
        self.connection.close()
        # Confirmation
        tkmb.showinfo("Info","You are disconnected from the database")
    

    ##### DATABASE INTERACTIVE DISPLAY #####

    def list_tables(self):
        """ Returns a list containing the name of the tables in the database"""
        # List the tables
        request = "SELECT name FROM sqlite_master WHERE type='table';"
        self.cursor.execute(request)
        tables = []
        for name in self.cursor.fetchall():
            # Do not consider sqlite sequence
            if name[0] != "sqlite_sequence":
                tables.append(name[0])
        return tables


    def interactive_structure(self, window):
        """Shows the structure of the database on the menu page. 
        Titles are buttons that can be clicked on to visualize (& edit ?) tables."""
        # Creates a main frame to hold the graph
        Main_frame = tk.Frame(window, borderwidth=2, relief=tk.GROOVE)
        Main_frame.pack(expand=True, fill=tk.BOTH)

        # Initial position for the first frame
        x_position = 20
        y_position = 20

        tables = self.list_tables()
        if "Supply_Chains" in tables:
            tables.remove("Supply_Chains")

        # Create a frame for Supply_Chains table
        table_frame = tk.Frame(Main_frame, borderwidth=2, relief=tk.GROOVE)
        x_position, y_position = 350, 50
        table_frame.place(x=x_position, y=y_position, anchor="n")

        # Button with the name of the table
        tab = Table("Supply_Chains", self)
        display_button = tk.Button(table_frame, text=tab.name, command=tab.display_dataframe)
        display_button.pack(side= tk.TOP, padx=5, pady=5)

        # Displaying the columns
        request = "PRAGMA table_info(Supply_Chains)"
        self.cursor.execute(request)
        for column in self.cursor.fetchall():  # Show the column's name
            tk.Label(table_frame, text=column[1]).pack()

        frame_width = 0
        for table in tables:
            # Create a frame for each table
            table_frame = tk.Frame(Main_frame, borderwidth=2, relief=tk.GROOVE)
            x_position, y_position = 100 + frame_width , 300
            table_frame.place(x=x_position, y=y_position)

            # Button with the name of the table
            tab = Table(table, self)
            display_button = tk.Button(table_frame, text=tab.name, command=tab.display_dataframe)
            display_button.pack(side= tk.TOP, padx=5, pady=5)

            # Displaying the columns
            request = "PRAGMA table_info(" + table + ")"
            self.cursor.execute(request)
            for column in self.cursor.fetchall():  # Show the column's name
                tk.Label(table_frame, text=column[1]).pack()
            
            # Adjust position for each frame to prevent overlap
            window.update_idletasks()  # Force the window to update
            frame_width += (table_frame.winfo_width() +20) # get frame width
        
    

    ###### TABLE MANAGEMENT ######

    def create_table(self, tab_name, column_names, column_types):
        """ Creates a table in the database"""
        # Create the string for SQL request
        columns = ", ".join(f"{name} {type}" for name, type in zip(column_names, column_types))
        # Create the table
        request = f"CREATE TABLE IF NOT EXISTS {tab_name.get()} ({columns})"
        self.cursor.execute(request)
        # Confirmation
        tkmb.showinfo("Info", "The table is created")


    def delete_table(self, name):
        """ Deletes a table named as input in the database"""
        request = "DROP TABLE IF EXISTS " + name
        self.cursor.execute(request)
        # Confirmation
        tkmb.showinfo("Info","The table is deleted")


