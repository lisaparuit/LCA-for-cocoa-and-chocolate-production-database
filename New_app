class Table(object):
    """ Pandas dataframe containing the informations from the SQL table in the database. 
    When manipulationg Table object, one should only use the attribute df and pandas methods.
    The database is modified using the method save."""
    
    def __init__(self, name, database, df = None):
        """ Creates an object that can interfere with the table in the database and be treated ad a pandas dataframe unsing its attribute df"""
        self.name = name
        self.database = database
        self.df = pd.read_sql('SELECT * FROM ' + self.name, self.database.connection)
        if self.name not in self.database.list_tables():
           tkmb.showinfo("Info","The table does not exist. Please create the table.")

    def save(self):
        """ Modifies the database with the values of its attribute df """
        self.df.to_sql(self.name, self.database.connection, if_exists='replace', index=False)
        # Confirmation
        tkmb.showinfo("Info","The table has been modified")
    

    ###### DISPLAY DATAFRAME PAGE #####

    def display_dataframe(self):
        """ Displays the dataframe in a new window 
        The user can edit the dataframe by double clicking on the label he wants to edit.
        Save button to save changes instead of Edit 
        """
        # Create a new window
        new_window = create_new_window("Display table")
        new_window.geometry("1000x600")

        # Define the Treeview
        tree = ttk.Treeview(new_window)
        
        # Define the column names
        tree["columns"] = self.df.columns.tolist()
        
        # Format our columns
        for column in self.df.columns:
            tree.column(column, anchor="w")
            tree.heading(column, text=column, anchor='w')

        # Inserting the DataFrame rows in Treeview
        for index, row in self.df.iterrows():
            print(self.name, row.tolist())
            tree.insert("", tk.END, values=row.tolist())
        tree.pack(expand=True, fill='both')

        # Create scrollbars
        v_scrollbar = tk.Scrollbar(new_window, orient=tk.VERTICAL, command=tree.yview)
        v_scrollbar.pack(side=tk.RIGHT, fill=tk.Y)
        h_scrollbar = tk.Scrollbar(new_window, orient=tk.HORIZONTAL, command=tree.xview)
        h_scrollbar.pack(side=tk.BOTTOM, fill=tk.X)

        # Configure the treeview to use the scrollbars
        tree.configure(yscrollcommand=v_scrollbar.set, xscrollcommand=h_scrollbar.set)

        # Pack the treeview last so it gets the remaining space
        tree.pack(side="left", fill="both", expand=True)

        # Bind the double-click event
        tree.bind("<Double-1>", on_label_double_click)
        
        # Exit & Save button
        tk.Button(new_window, text="Close", command=new_window.destroy).place(x=450, y=560, anchor="center")
        tk.Button(new_window, text="Save", command=lambda: [self.save]).place(x=550, y=560, anchor="center")

    
    ###### ADD DATA #####

    def ask_row(self, new_window, StudyID = None, SupplyChainID = None, SupplyChainType = None):
        """In an input window, creates the entry form for new_row creation in the table
        and return a dictionary in order to modify the dataframe through add_row()
        """
        # Getting the column names for the table
        request = "PRAGMA table_info("+self.name+")"
        self.database.cursor.execute(request)
        Dict = {}
        for column in self.database.cursor.fetchall():  # Show the column's name
            # if the column is a fixed primary key, it is not asked to the user
            if column[1] == "StudyID" and StudyID is not None: 
                Dict.update({column[1] : StudyID})
            elif column[1] == "SupplyChainID" and SupplyChainID is not None:
                Dict.update({column[1] : SupplyChainID})
            elif column[1] == "SupplyChainType" and SupplyChainType is not None:
                Dict.update({column[1] : SupplyChainType})
            # else the column is asked to the user
            else:
                Dict.update({column[1] : tk.StringVar()})
        
        # Entry form only for the columns that are not fixed primary keys
        keys_with_stringvar_values = return_keys_with_stringvar_values_as_list(Dict)              
        for var in keys_with_stringvar_values:
            tk.Label(new_window,text=var).pack()
            tk.Entry(new_window, textvariable = Dict[var], width=100).pack()
        
        # Confirm variables entry
        tk.Button(new_window, text="Confirm", command=new_window.destroy).pack()
        new_window.wait_window()

        return(Dict)


    def add_row(self, row):
        """ Adds a row to the table the row must be in the form of a dictionary with the column 
        names as keys and the values as values."""
        self.df = self.df._append(row, ignore_index=True)
        self.save()
        # Confirmation 
        tkmb.showinfo("Info","The row has been added to the table")


    
    ######## REQUESTS ########

    def return_list_of_values_in_column(self, column_name):
        """ Returns a list of the values in the column"""
        return pd.unique(self.df[column_name]).to_list()



### Functions that are used in the code but are not part of the classes:

def create_new_window(title):
    """ Creates a new window with a title"""
    new_window = tk.Toplevel(window)
    new_window.title(title)
    return new_window

def on_label_double_click(event):
    # Prompt the user for new text
    new_text = simpledialog.askstring("Input", "Enter new text:", parent=event.widget.master)
    if new_text is not None:  # Check if the user clicked 'Cancel'
        event.widget.config(text=new_text)

def return_keys_with_stringvar_values_as_list(dictionary):
    list_keys = []
    for key, value in dictionary.items():
        if isinstance(value, tk.StringVar):
            list_keys.append(key)
    return list_keys

